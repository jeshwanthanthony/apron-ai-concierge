# ─────────────────────────────────────────────────────────────
# Copy the secret values into a file named `.env.local` (which is
# git-ignored via `*.local`) so they are NEVER committed/pushed.
# The public Supabase values live in `.env` and are safe to commit.
# ─────────────────────────────────────────────────────────────

# Server-side only. Powers the AI concierge (/api/concierge).
# Get one at https://platform.openai.com/api-keys
# ⚠️ Put the REAL key in `.env.local` (git-ignored), NOT here.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4.1-mini (best value for this concierge:
# strong instruction-following + grounding, fast, cheap).
# Cheaper: gpt-4o-mini. Newer: gpt-5-mini / gpt-5-nano.
OPENAI_MODEL=gpt-4.1-mini

# ─────────────────────────────────────────────────────────────
# Billing (Stripe). Server-side only — put the REAL values in
# `.env.local` locally, and set them as secrets on Cloudflare in prod.
# ─────────────────────────────────────────────────────────────

# Secret API key — https://dashboard.stripe.com/apikeys  (sk_live_… / sk_test_…)
STRIPE_SECRET_KEY=

# Webhook signing secret — from the webhook endpoint you create in Stripe (whsec_…)
STRIPE_WEBHOOK_SECRET=

# Recurring Price IDs for each plan (price_…). Create two products in Stripe:
#   Pro Monthly  $19/month   → STRIPE_PRICE_MONTHLY
#   Pro Annual   $179/year   → STRIPE_PRICE_ANNUAL
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# ─────────────────────────────────────────────────────────────
# Supabase service role — used ONLY by the Stripe webhook to update a
# restaurant's plan (bypasses RLS). NEVER expose this to the browser.
# Project Settings → API → service_role key.
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Public URL of the deployed app (used to build Stripe redirect URLs
# when the request Origin header isn't available). e.g. https://yourdomain.com
PUBLIC_APP_URL=
